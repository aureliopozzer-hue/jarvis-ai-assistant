// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String     @id @default(cuid())
  title     String     @default("Nova Conversa")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  role           String       // "user" | "assistant" | "system"
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model JarvisSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "alert" | "info" | "warning" | "success"
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ProactiveEvent {
  id        String   @id @default(cuid())
  eventType String   // "web_search" | "news" | "reminder" | "system"
  title     String
  content   String
  active    Boolean  @default(true)
  interval  Int      @default(300) // seconds
  lastRun   DateTime?
  createdAt DateTime @default(now())
}

model Memory {
  id        String   @id @default(cuid())
  category  String   // "preference" | "fact" | "routine" | "context" | "note"
  key       String
  value     String
  source    String   @default("user") // "user" | "system" | "inferred"
  important Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key])
}

model UserFact {
  id        String   @id @default(cuid())
  fact      String
  context   String?  // conversation context where this was learned
  confidence Float  @default(1.0)
  createdAt DateTime @default(now())
}

model EmailAccount {
  id           String  @id @default(cuid())
  provider     String  // "gmail" | "outlook" | "custom"
  email        String  @unique
  accessToken  String
  refreshToken String?
  isActive     Boolean @default(true)
  lastSync     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  emails       Email[]
}

model Email {
  id         String       @id @default(cuid())
  accountId  String
  account    EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messageId  String       @unique // provider message ID
  from       String
  to         String
  subject    String
  body       String
  snippet    String       // first 200 chars
  isRead     Boolean      @default(false)
  isStarred  Boolean      @default(false)
  labels     String       @default("[]") // JSON array of labels
  receivedAt DateTime
  createdAt  DateTime     @default(now())
}

model SocialAccount {
  id           String       @id @default(cuid())
  platform     String       // "instagram" | "twitter" | "linkedin" | "facebook" | "tiktok"
  username     String
  accessToken  String
  refreshToken String?
  isActive     Boolean      @default(true)
  lastSync     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  posts        SocialPost[]
}

model SocialPost {
  id        String        @id @default(cuid())
  accountId String
  account   SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  postId    String        @unique // platform post ID
  content   String
  mediaUrls String        @default("[]") // JSON array
  likes     Int           @default(0)
  comments  Int           @default(0)
  shares    Int           @default(0)
  postedAt  DateTime
  createdAt DateTime      @default(now())
}

model Campaign {
  id        String    @id @default(cuid())
  name      String
  type      String    // "email" | "social" | "ads" | "content"
  status    String    @default("draft") // "draft" | "active" | "paused" | "completed"
  budget    Float     @default(0)
  spent     Float     @default(0)
  metrics   String    @default("{}") // JSON: impressions, clicks, conversions, ctr, roi
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  startTime   DateTime
  endTime     DateTime
  recurrence  String?  // RRULE format
  reminder    Int?     // minutes before
  source      String   @default("jarvis") // "jarvis" | "google" | "outlook"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FileItem {
  id        String   @id @default(cuid())
  name      String
  type      String   // "document" | "image" | "code" | "spreadsheet" | "other"
  size      Int      // bytes
  path      String
  content   String?  // text content for search
  tags      String   @default("[]") // JSON array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StripeConfig {
  id            String   @id @default(cuid())
  publicKey     String
  secretKey     String
  webhookSecret String?
  isActive      Boolean  @default(true)
  mode          String   @default("test") // "test" | "live"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscription {
  id                 String   @id @default(cuid())
  customerId         String   @unique
  email              String
  plan               String   // "free" | "pro" | "enterprise"
  status             String   @default("active") // "active" | "canceled" | "past_due" | "trialing"
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model FinanceWatchlist {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  type      String   @default("STOCKS") // "STOCKS" | "ETF" | "CRYPTO" | "INDEX"
  quantity  Float?
  avgPrice  Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinanceAlert {
  id        String   @id @default(cuid())
  ticker    String
  type      String   // "above" | "below" | "change_percent"
  value     Float
  isActive  Boolean  @default(true)
  triggered Boolean  @default(false)
  createdAt DateTime @default(now())
}
